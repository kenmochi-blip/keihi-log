---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  headings?: Heading[];
  readingTime?: number;
}

const {
  title, description, pubDate, updatedDate,
  tags = [], headings = [], readingTime = 3,
} = Astro.props;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length >= 3;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | 経費ログ ブログ</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <style>
    :root {
      --brand: #0d6efd;
      --brand-dark: #0a58ca;
      --text: #1a202c;
      --muted: #6c757d;
      --border: #e9ecef;
      --bg: #f7f8fc;
      --card-bg: #ffffff;
    }
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 1rem;
      color: var(--text);
      background: var(--bg);
      line-height: 1.7;
    }

    /* 読書進捗バー */
    #read-progress {
      position: fixed;
      top: 0;
      left: 0;
      width: 0%;
      height: 3px;
      background: linear-gradient(90deg, var(--brand), #6610f2);
      z-index: 9999;
      transition: width 0.1s linear;
    }

    /* ナビバー */
    .blog-nav {
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
    }
    .blog-nav a { text-decoration: none; color: var(--text); font-weight: 700; }
    .blog-nav a:hover { color: var(--brand); }
    .blog-nav .site-name { font-size: 0.95rem; font-weight: 700; }

    /* レイアウト */
    .blog-container {
      max-width: 1060px;
      margin: 0 auto;
      padding: 2rem 1rem 4rem;
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    @media (min-width: 992px) {
      .blog-container {
        grid-template-columns: 1fr 260px;
        align-items: start;
        padding: 3rem 1.5rem 5rem;
      }
    }

    /* 記事エリア */
    .article-main {
      background: var(--card-bg);
      border-radius: 16px;
      padding: 2rem 1.5rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      min-width: 0;
    }
    @media (min-width: 768px) {
      .article-main { padding: 3rem 3.5rem; }
    }

    /* タグ */
    .tag-badge {
      background: #eef2ff;
      color: #4361ee;
      font-size: 0.72rem;
      font-weight: 500;
      padding: 0.28em 0.75em;
      border-radius: 20px;
      text-decoration: none;
      transition: background 0.15s;
    }
    .tag-badge:hover { background: #dde6ff; }

    /* 記事タイトル */
    .article-title {
      font-size: 1.55rem;
      font-weight: 900;
      line-height: 1.45;
      letter-spacing: -0.02em;
      color: var(--text);
    }
    @media (min-width: 768px) { .article-title { font-size: 2rem; } }

    /* メタ情報 */
    .article-meta {
      font-size: 0.8rem;
      color: var(--muted);
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
    }

    /* 記事本文 */
    .article-body { line-height: 1.9; }
    .article-body h2 {
      font-size: 1.3rem;
      font-weight: 800;
      margin-top: 3rem;
      margin-bottom: 1rem;
      padding: 0.55rem 0.9rem;
      background: linear-gradient(135deg, #eef2ff 0%, #f0f9ff 100%);
      border-left: 4px solid var(--brand);
      border-radius: 0 8px 8px 0;
    }
    .article-body h3 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      padding-bottom: 0.3rem;
      border-bottom: 2px dotted #c7d7fb;
    }
    .article-body p { margin-bottom: 1.4rem; }
    .article-body ul, .article-body ol {
      margin-bottom: 1.4rem;
      padding-left: 1.6rem;
    }
    .article-body li { margin-bottom: 0.4rem; }
    .article-body a { color: var(--brand); text-underline-offset: 3px; }
    .article-body a:hover { color: var(--brand-dark); }
    .article-body strong { font-weight: 700; }
    .article-body table {
      width: 100%;
      font-size: 0.875rem;
      border-collapse: collapse;
      margin-bottom: 1.5rem;
      border-radius: 8px;
      overflow: hidden;
    }
    .article-body table th {
      background: #3a5f82;
      color: #fff;
      padding: 0.55rem 0.9rem;
      font-weight: 600;
      text-align: left;
    }
    .article-body table td {
      padding: 0.5rem 0.9rem;
      border-bottom: 1px solid var(--border);
    }
    .article-body table tr:last-child td { border-bottom: none; }
    .article-body table tr:hover td { background: #f5f8ff; }
    .article-body blockquote {
      border-left: 4px solid var(--brand);
      background: #f0f5ff;
      padding: 0.8rem 1.2rem;
      border-radius: 0 8px 8px 0;
      margin-bottom: 1.4rem;
      font-style: italic;
      color: #3d5a80;
    }
    .article-body code {
      background: #f1f3f5;
      padding: 0.15em 0.4em;
      border-radius: 4px;
      font-size: 0.875em;
      font-family: 'Menlo', 'Monaco', monospace;
    }
    .article-body pre {
      background: #1e293b;
      color: #e2e8f0;
      padding: 1.2rem 1.5rem;
      border-radius: 10px;
      overflow-x: auto;
      margin-bottom: 1.4rem;
    }
    .article-body pre code { background: none; padding: 0; color: inherit; font-size: 0.875em; }
    .article-body hr { border: none; border-top: 2px dashed var(--border); margin: 2.5rem 0; }

    /* CTA */
    .article-cta {
      background: linear-gradient(135deg, #eef2ff 0%, #f0f9ff 100%);
      border: 2px solid #c7d7fb;
      border-radius: 14px;
      padding: 1.75rem;
      margin-top: 3rem;
      text-align: center;
    }
    .article-cta .cta-title { font-size: 1.1rem; font-weight: 800; margin-bottom: 0.5rem; }
    .article-cta .cta-desc { font-size: 0.85rem; color: var(--muted); margin-bottom: 1.25rem; line-height: 1.7; }

    /* サイドバー */
    .sidebar { position: sticky; top: 72px; }
    .toc-card {
      background: var(--card-bg);
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .toc-title {
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }
    .toc-list { list-style: none; padding: 0; margin: 0; }
    .toc-list li { margin-bottom: 0.35rem; }
    .toc-list a {
      font-size: 0.82rem;
      color: var(--muted);
      text-decoration: none;
      display: block;
      padding: 0.15rem 0;
      border-left: 2px solid transparent;
      padding-left: 0.6rem;
      transition: color 0.15s, border-color 0.15s;
      line-height: 1.5;
    }
    .toc-list a:hover, .toc-list a.active {
      color: var(--brand);
      border-left-color: var(--brand);
    }
    .toc-list .toc-h3 a { padding-left: 1.4rem; font-size: 0.78rem; }

    /* パンくず */
    .breadcrumb { font-size: 0.78rem; }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--muted); }

    /* フッター */
    .blog-footer {
      border-top: 1px solid var(--border);
      background: var(--card-bg);
    }
  </style>
</head>
<body>
  <div id="read-progress"></div>

  <!-- ナビバー -->
  <nav class="blog-nav py-2 px-3 px-md-4 d-flex align-items-center justify-content-between sticky-top">
    <a href="/" class="d-flex align-items-center gap-2">
      <img src="/favicon.svg" width="22" height="22" alt="" />
      <span class="site-name">経費ログ</span>
    </a>
    <div class="d-flex gap-3 align-items-center">
      <a href="/blog/" class="text-muted small">ブログ</a>
      <a href="/" class="btn btn-primary btn-sm px-3" style="font-size:0.82rem;">無料で試す</a>
    </div>
  </nav>

  <!-- メインコンテンツ -->
  <div class="blog-container">

    <!-- 記事本文カラム -->
    <article class="article-main">
      <!-- パンくず -->
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb mb-0">
          <li class="breadcrumb-item"><a href="/" class="text-muted">ホーム</a></li>
          <li class="breadcrumb-item"><a href="/blog/" class="text-muted">ブログ</a></li>
          <li class="breadcrumb-item active text-truncate" style="max-width:180px;">{title}</li>
        </ol>
      </nav>

      <!-- タグ -->
      {tags.length > 0 && (
        <div class="mb-3 d-flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="tag-badge">#{tag}</span>
          ))}
        </div>
      )}

      <!-- タイトル -->
      <h1 class="article-title mb-3">{title}</h1>

      <!-- メタ情報 -->
      <div class="article-meta mb-4">
        <span><i class="bi bi-calendar3 me-1"></i>
          <time datetime={pubDate.toISOString()}>{fmtDate(pubDate)}</time>
        </span>
        {updatedDate && (
          <span><i class="bi bi-arrow-clockwise me-1"></i>
            更新: <time datetime={updatedDate.toISOString()}>{fmtDate(updatedDate)}</time>
          </span>
        )}
        <span><i class="bi bi-clock me-1"></i>約{readingTime}分で読めます</span>
      </div>

      <hr class="mb-4" />

      <!-- モバイル用TOC（記事内） -->
      {hasToc && (
        <details class="d-lg-none mb-4" style="background:#f7f8fc;border-radius:10px;padding:1rem 1.25rem;border:1px solid var(--border);">
          <summary style="font-size:0.85rem;font-weight:700;cursor:pointer;list-style:none;display:flex;align-items:center;gap:0.5rem;">
            <i class="bi bi-list-ul text-primary"></i>目次
          </summary>
          <ul class="toc-list mt-3">
            {tocHeadings.map(h => (
              <li class={h.depth === 3 ? 'toc-h3' : ''}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </details>
      )}

      <!-- 記事本文 -->
      <div class="article-body">
        <slot />
      </div>

      <!-- CTA -->
      <div class="article-cta">
        <div class="cta-title">経費精算をもっとかんたんに</div>
        <p class="cta-desc">
          AI領収書解析・電帳法対応・Google スプレッドシート連携<br />
          月額330円〜 ／ 2週間無料トライアルあり
        </p>
        <a href="/" class="btn btn-primary px-4" style="font-weight:700;">無料で試してみる →</a>
      </div>
    </article>

    <!-- サイドバー（PC） -->
    {hasToc && (
      <aside class="sidebar d-none d-lg-block">
        <div class="toc-card">
          <div class="toc-title"><i class="bi bi-list-ul me-1"></i>目次</div>
          <ul class="toc-list" id="toc">
            {tocHeadings.map(h => (
              <li class={h.depth === 3 ? 'toc-h3' : ''}>
                <a href={`#${h.slug}`} data-toc={h.slug}>{h.text}</a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    )}

  </div>

  <!-- フッター -->
  <footer class="blog-footer py-4">
    <div class="container text-center" style="font-size:0.8rem;color:var(--muted);">
      <div class="d-flex justify-content-center flex-wrap gap-3 mb-2">
        <a href="/privacy" class="text-muted text-decoration-none">プライバシーポリシー</a>
        <a href="/terms" class="text-muted text-decoration-none">利用規約</a>
        <a href="/faq" class="text-muted text-decoration-none">よくある質問</a>
        <a href="/blog/" class="text-muted text-decoration-none">ブログ一覧</a>
      </div>
      <div>© 2025 合同会社Smart&amp;Smooth</div>
    </div>
  </footer>

  <script>
    // 読書進捗バー
    const bar = document.getElementById('read-progress');
    function updateProgress() {
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      if (bar) bar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
    }
    window.addEventListener('scroll', updateProgress, { passive: true });

    // 目次アクティブハイライト
    const tocLinks = document.querySelectorAll('[data-toc]');
    if (tocLinks.length) {
      const headingEls = [...tocLinks].map(a =>
        document.getElementById((a as HTMLAnchorElement).dataset.toc!)
      ).filter(Boolean);

      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          const link = document.querySelector(`[data-toc="${entry.target.id}"]`);
          if (link) link.classList.toggle('active', entry.isIntersecting);
        });
      }, { rootMargin: '-20% 0px -70% 0px' });

      headingEls.forEach(el => observer.observe(el!));
    }
  </script>
</body>
</html>
