---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

import { getAuthor } from '../authors';
import { BLOG_PUBLISHED } from '../siteConfig';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  headings?: Heading[];
  readingTime?: number;
  author?: string;
}

const {
  title, description, pubDate, updatedDate,
  tags = [], headings = [], readingTime = 3, author,
} = Astro.props;

const writer = getAuthor(author);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length >= 3;

const canonical = new URL(Astro.url.pathname, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  url: canonical,
  mainEntityOfPage: canonical,
  image: 'https://keihi-log.com/icons/icon-512.png',
  author: { '@type': 'Organization', name: '経費ログ' },
  publisher: {
    '@type': 'Organization',
    name: '合同会社Smart&Smooth',
    logo: { '@type': 'ImageObject', url: 'https://keihi-log.com/icons/icon-512.png' },
  },
};
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{`${title}｜経費ログ ブログ`}</title>
  <meta name="description" content={description} />
  {!BLOG_PUBLISHED && <meta name="robots" content="noindex,nofollow" />}
  <link rel="canonical" href={canonical} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="経費ログ" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://keihi-log.com/icons/icon-512.png" />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://keihi-log.com/icons/icon-512.png" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <style>
    :root {
      --brand-h: 217; --brand-s: 97%; --brand-l: 52%;
      --brand: hsl(var(--brand-h), var(--brand-s), var(--brand-l));
      --bs-primary: var(--brand);
      --bs-primary-rgb: 13, 110, 253;
      --brand-dark: #0a58ca;
      --text: #212529;
      --muted: #6c757d;
      --border: #e9ecef;
      --bg: #f7f8fc;
      --card-bg: #ffffff;
    }
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Noto Sans JP', sans-serif;
      font-size: 1rem;
      color: var(--text);
      background: var(--bg);
      line-height: 1.7;
    }

    /* 読書進捗バー */
    #read-progress {
      position: fixed;
      top: 0;
      left: 0;
      width: 0%;
      height: 3px;
      background: var(--accent);
      z-index: 9999;
      transition: width 0.1s linear;
    }

    /* ナビバー（LP統一） */
    .blog-nav {
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(10px);
      box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    }
    .blog-nav .brand { text-decoration: none; color: var(--brand); font-weight: 900; font-size: 1.35rem; display: inline-flex; align-items: center; }
    .blog-nav .logo-svg { width: 32px; height: 32px; margin-right: 6px; }
    .blog-nav .nav-link-sm { color: #495057; font-weight: 500; font-size: 0.88rem; text-decoration: none; }
    .blog-nav .nav-link-sm:hover { color: var(--brand); }

    /* レイアウト */
    .blog-container {
      max-width: 1060px;
      margin: 0 auto;
      padding: 2rem 1rem 4rem;
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    @media (min-width: 992px) {
      .blog-container {
        grid-template-columns: 240px 1fr;
        align-items: start;
        padding: 3rem 1.5rem 5rem;
      }
    }

    /* 記事エリア（書き手の色で淡く色分け） */
    .article-main {
      background: color-mix(in srgb, var(--tint) 45%, #fff);
      border-radius: 16px;
      border-top: 4px solid var(--accent);
      padding: 2rem 1.5rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      min-width: 0;
    }
    @media (min-width: 992px) {
      .article-main { padding: 2.5rem 3rem; }
    }
    @media (min-width: 992px) {
      .blog-container:not(:has(.sidebar)) .article-main,
      .article-main:first-child {
        grid-column: 1 / -1;
      }
    }

    /* タグ */
    .tag-badge {
      background: #eef2ff;
      color: #4361ee;
      font-size: 0.72rem;
      font-weight: 500;
      padding: 0.28em 0.75em;
      border-radius: 20px;
      text-decoration: none;
      transition: background 0.15s;
    }
    .tag-badge:hover { background: #dde6ff; }

    /* 記事タイトル */
    .article-title {
      font-size: 1.35rem;
      font-weight: 900;
      line-height: 1.55;
      letter-spacing: -0.01em;
      color: var(--text);
      margin-top: 0.25rem;
    }
    @media (min-width: 768px) { .article-title { font-size: 1.6rem; line-height: 1.5; } }

    /* メタ情報 */
    .article-meta {
      font-size: 0.8rem;
      color: var(--muted);
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
    }

    /* 記事本文（markdown はスロット由来のため :global で指定） */
    .article-body {
      font-size: 1.02rem;
      line-height: 2;
      color: #2f343b;
      letter-spacing: 0.01em;
      font-feature-settings: "palt";
      word-break: break-word;
    }
    .article-body :global(h2) {
      font-size: 1.18rem;
      font-weight: 700;
      line-height: 1.6;
      color: var(--text);
      margin: 3rem 0 1.1rem;
      padding-left: 0.85rem;
      border-left: 4px solid var(--accent);
    }
    .article-body :global(h2:first-child) { margin-top: 0.5rem; }
    .article-body :global(h3) {
      font-size: 1.04rem;
      font-weight: 700;
      line-height: 1.6;
      color: #3a4048;
      margin: 2.2rem 0 0.7rem;
    }
    .article-body :global(p) { margin: 0 0 1.6rem; }
    .article-body :global(ul), .article-body :global(ol) {
      margin: 0 0 1.6rem;
      padding-left: 1.5rem;
    }
    .article-body :global(li) { margin-bottom: 0.5rem; }
    .article-body :global(li::marker) { color: var(--accent); }
    .article-body :global(a) {
      color: var(--brand);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }
    .article-body :global(a:hover) { color: var(--brand-dark); }
    .article-body :global(strong) {
      font-weight: 700;
      background: linear-gradient(transparent 62%, color-mix(in srgb, var(--accent) 22%, transparent) 0);
    }
    .article-body :global(table) {
      width: 100%;
      font-size: 0.9rem;
      border-collapse: collapse;
      margin: 0 0 1.8rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
    }
    .article-body :global(thead th) {
      background: #f3f5f9;
      color: #3a4048;
      padding: 0.6rem 0.95rem;
      font-weight: 700;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }
    .article-body :global(td) {
      padding: 0.55rem 0.95rem;
      border-bottom: 1px solid var(--border);
    }
    .article-body :global(tbody tr:last-child td) { border-bottom: none; }
    .article-body :global(blockquote) {
      border-left: 3px solid var(--accent);
      background: var(--tint);
      padding: 0.9rem 1.3rem;
      border-radius: 0 10px 10px 0;
      margin: 0 0 1.6rem;
      color: #4a5158;
    }
    .article-body :global(blockquote p) { margin: 0; }
    .article-body :global(code) {
      background: #f1f3f5;
      padding: 0.15em 0.4em;
      border-radius: 4px;
      font-size: 0.875em;
      font-family: 'Menlo', 'Monaco', monospace;
    }
    .article-body :global(pre) {
      background: #1e293b;
      color: #e2e8f0;
      padding: 1.2rem 1.5rem;
      border-radius: 10px;
      overflow-x: auto;
      margin: 0 0 1.6rem;
    }
    .article-body :global(pre code) { background: none; padding: 0; color: inherit; font-size: 0.875em; }
    .article-body :global(hr) { border: none; border-top: 1px solid var(--border); margin: 2.75rem 0; }
    .article-body :global(img) { max-width: 100%; height: auto; border-radius: 10px; margin: 0.5rem 0 1.6rem; }

    /* 書き手バイライン */
    .byline {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.3em 0.8em 0.3em 0.6em;
      background: var(--tint);
      border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));
      border-radius: 20px;
      font-size: 0.78rem;
      font-weight: 600;
      color: color-mix(in srgb, var(--accent) 70%, #000);
    }
    .byline i { font-size: 0.9rem; }

    /* CTA */
    .article-cta {
      background: linear-gradient(135deg, #eef2ff 0%, #f0f9ff 100%);
      border: 2px solid #c7d7fb;
      border-radius: 14px;
      padding: 1.75rem;
      margin-top: 3rem;
      text-align: center;
    }
    .article-cta .cta-title { font-size: 1.1rem; font-weight: 800; margin-bottom: 0.5rem; }
    .article-cta .cta-desc { font-size: 0.85rem; color: var(--muted); margin-bottom: 1.25rem; line-height: 1.7; }

    /* サイドバー */
    .sidebar { position: sticky; top: 72px; }
    .toc-card {
      background: var(--card-bg);
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .toc-title {
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }
    .toc-list { list-style: none; padding: 0; margin: 0; }
    .toc-list li { margin-bottom: 0.35rem; }
    .toc-list a {
      font-size: 0.82rem;
      color: var(--muted);
      text-decoration: none;
      display: block;
      padding: 0.15rem 0;
      border-left: 2px solid transparent;
      padding-left: 0.6rem;
      transition: color 0.15s, border-color 0.15s;
      line-height: 1.5;
    }
    .toc-list a:hover, .toc-list a.active {
      color: var(--brand);
      border-left-color: var(--brand);
    }
    .toc-list .toc-h3 a { padding-left: 1.4rem; font-size: 0.78rem; }

    /* パンくず */
    .breadcrumb { font-size: 0.78rem; }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--muted); }

    /* フッター（LP統一・濃紺） */
    .blog-footer {
      background: linear-gradient(160deg, #0d2d5a 0%, #163866 100%);
      color: #adb5bd;
      border-top: 3px solid rgba(110, 168, 254, 0.5);
    }
    .blog-footer a { color: #adb5bd; text-decoration: none; transition: color 0.2s; }
    .blog-footer a:hover { color: #6ea8fe; }
  </style>
</head>
<body style={`--accent:${writer.accent};--tint:${writer.tint};`}>
  <div id="read-progress"></div>

  <!-- ブランドロゴ定義 -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <symbol id="logo-keihilog" viewBox="0 0 100 100">
        <defs>
          <linearGradient id="logoGrad" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#29B6F6"/>
            <stop offset="100%" stop-color="#3F51B5"/>
          </linearGradient>
        </defs>
        <path d="M18,4 L74,4 Q80,4 80,10 L80,65 L72,73 L63,65 L55,73 L47,65 L38,73 L30,65 L22,73 L14,65 L14,10 Q14,4 18,4 Z" fill="url(#logoGrad)"/>
        <rect x="22" y="18" width="42" height="6" rx="3" fill="white"/>
        <rect x="22" y="30" width="37" height="6" rx="3" fill="white" opacity="0.9"/>
        <rect x="22" y="42" width="31" height="6" rx="3" fill="white" opacity="0.85"/>
        <circle cx="72" cy="76" r="22" fill="#388E3C"/>
        <polyline points="61,76 69,84 83,64" fill="none" stroke="white" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
      </symbol>
    </defs>
  </svg>

  <!-- ナビバー -->
  <nav class="blog-nav py-2 px-3 px-md-4 d-flex align-items-center justify-content-between sticky-top">
    <a href="/" class="brand">
      <svg class="logo-svg"><use href="#logo-keihilog"/></svg>
      経費ログ
    </a>
    <div class="d-flex gap-3 align-items-center">
      <a href="/blog/" class="nav-link-sm">ブログ</a>
      <a href="/#pricing" class="btn btn-primary btn-sm rounded-pill px-3" style="font-size:0.82rem;">無料で試す</a>
    </div>
  </nav>

  <!-- メインコンテンツ -->
  <div class="blog-container">

    <!-- サイドバー（PC・左） -->
    {hasToc && (
      <aside class="sidebar d-none d-lg-block">
        <div class="toc-card">
          <div class="toc-title"><i class="bi bi-list-ul me-1"></i>目次</div>
          <ul class="toc-list" id="toc">
            {tocHeadings.map(h => (
              <li class={h.depth === 3 ? 'toc-h3' : ''}>
                <a href={`#${h.slug}`} data-toc={h.slug}>{h.text}</a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    )}

    <!-- 記事本文カラム -->
    <article class="article-main">
      <!-- パンくず -->
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb mb-0">
          <li class="breadcrumb-item"><a href="/" class="text-muted">ホーム</a></li>
          <li class="breadcrumb-item"><a href="/blog/" class="text-muted">ブログ</a></li>
          <li class="breadcrumb-item active text-truncate" style="max-width:180px;">{title}</li>
        </ol>
      </nav>

      <!-- タグ -->
      {tags.length > 0 && (
        <div class="mb-3 d-flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="tag-badge">#{tag}</span>
          ))}
        </div>
      )}

      <!-- タイトル -->
      <h1 class="article-title mb-3">{title}</h1>

      <!-- メタ情報 -->
      <div class="article-meta mb-4">
        <span><i class="bi bi-calendar3 me-1"></i>
          <time datetime={pubDate.toISOString()}>{fmtDate(pubDate)}</time>
        </span>
        {updatedDate && (
          <span><i class="bi bi-arrow-clockwise me-1"></i>
            更新: <time datetime={updatedDate.toISOString()}>{fmtDate(updatedDate)}</time>
          </span>
        )}
        <span><i class="bi bi-clock me-1"></i>約{readingTime}分</span>
      </div>

      <!-- 書き手ラベル -->
      <span class="byline mb-4">
        <i class={`bi ${writer.icon}`}></i>{writer.label}
      </span>

      <hr class="mb-4" />

      <!-- モバイル用TOC（記事内） -->
      {hasToc && (
        <details class="d-lg-none mb-4" style="background:#f7f8fc;border-radius:10px;padding:1rem 1.25rem;border:1px solid var(--border);">
          <summary style="font-size:0.85rem;font-weight:700;cursor:pointer;list-style:none;display:flex;align-items:center;gap:0.5rem;">
            <i class="bi bi-list-ul text-primary"></i>目次
          </summary>
          <ul class="toc-list mt-3">
            {tocHeadings.map(h => (
              <li class={h.depth === 3 ? 'toc-h3' : ''}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </details>
      )}

      <!-- 記事本文 -->
      <div class="article-body">
        <slot />
      </div>

      <!-- CTA -->
      <div class="article-cta">
        <div class="cta-title">経費精算をもっとかんたんに</div>
        <p class="cta-desc">
          AI領収書解析・電帳法対応・Google スプレッドシート連携<br />
          月額330円〜 ／ 2週間無料トライアルあり
        </p>
        <a href="/#pricing" class="btn btn-primary px-4" style="font-weight:700;">無料で試してみる →</a>
      </div>
    </article>

  </div>

  <!-- フッター -->
  <footer class="blog-footer py-4">
    <div class="container text-center" style="font-size:0.8rem;">
      <div class="d-flex justify-content-center flex-wrap gap-3 mb-2">
        <a href="/privacy">プライバシーポリシー</a>
        <a href="/terms">利用規約</a>
        <a href="/faq">よくある質問</a>
        <a href="/blog/">ブログ一覧</a>
      </div>
      <div style="opacity:0.7;">© 2025 合同会社Smart&amp;Smooth</div>
    </div>
  </footer>

  <script>
    // 読書進捗バー
    const bar = document.getElementById('read-progress');
    function updateProgress() {
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      if (bar) bar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
    }
    window.addEventListener('scroll', updateProgress, { passive: true });

    // 目次アクティブハイライト
    const tocLinks = document.querySelectorAll('[data-toc]');
    if (tocLinks.length) {
      const headingEls = [...tocLinks].map(a =>
        document.getElementById((a as HTMLAnchorElement).dataset.toc!)
      ).filter(Boolean);

      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          const link = document.querySelector(`[data-toc="${entry.target.id}"]`);
          if (link) link.classList.toggle('active', entry.isIntersecting);
        });
      }, { rootMargin: '-20% 0px -70% 0px' });

      headingEls.forEach(el => observer.observe(el!));
    }
  </script>
</body>
</html>
