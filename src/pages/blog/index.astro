---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmtDate = (d: Date) =>
  d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ブログ | 経費ログ</title>
  <meta name="description" content="経費精算・電子帳簿保存法・フリーランスの経費管理に関するお役立ち情報を発信しています。" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <style>
    body { font-size: 0.95rem; }
    .blog-nav { border-bottom: 1px solid #dee2e6; }
    .blog-nav a { text-decoration: none; color: #212529; font-weight: 600; }
    .blog-nav a:hover { color: #0d6efd; }
    .post-card { transition: box-shadow 0.15s; text-decoration: none; color: inherit; display: block; }
    .post-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.10); }
    .post-title { font-size: 1.05rem; font-weight: 700; line-height: 1.45; }
    .tag-badge { background: #e8f0fe; color: #1a56db; font-size: 0.72rem; padding: 0.2em 0.6em; border-radius: 20px; }
  </style>
</head>
<body class="bg-light">

  <nav class="blog-nav bg-white py-2 px-3 px-md-4 d-flex align-items-center justify-content-between sticky-top">
    <a href="/" class="d-flex align-items-center gap-2">
      <img src="/favicon.svg" width="24" height="24" alt="" />
      <span>経費ログ</span>
    </a>
    <div class="d-flex gap-3 align-items-center">
      <span class="text-primary fw-semibold small">ブログ</span>
      <a href="/" class="btn btn-primary btn-sm px-3">無料で試す</a>
    </div>
  </nav>

  <main class="container py-4 py-md-5" style="max-width:800px;">
    <h1 class="fw-bold mb-1" style="font-size:1.5rem;">ブログ</h1>
    <p class="text-muted small mb-4">経費精算・電帳法・フリーランスの経費管理に関するお役立ち情報</p>

    {posts.length === 0 ? (
      <p class="text-muted">記事はまだありません。</p>
    ) : (
      <div class="d-flex flex-column gap-3">
        {posts.map(post => (
          <a href={`/blog/${post.id}/`} class="post-card card border-0 shadow-sm">
            <div class="card-body py-3">
              <div class="d-flex flex-wrap gap-1 mb-2">
                {post.data.tags.map(tag => (
                  <span class="tag-badge">#{tag}</span>
                ))}
              </div>
              <div class="post-title mb-1">{post.data.title}</div>
              <p class="text-muted small mb-2" style="line-height:1.6;">{post.data.description}</p>
              <div class="text-muted" style="font-size:0.75rem;">
                <i class="bi bi-calendar3 me-1"></i>
                <time datetime={post.data.pubDate.toISOString()}>{fmtDate(post.data.pubDate)}</time>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>

  <footer class="py-4 mt-2 border-top">
    <div class="container text-center text-muted small">
      <a href="/privacy" class="me-3">プライバシーポリシー</a>
      <a href="/terms" class="me-3">利用規約</a>
      <a href="/faq" class="me-3">よくある質問</a>
      <div class="mt-2">© 2025 合同会社Smart&amp;Smooth</div>
    </div>
  </footer>

</body>
</html>
