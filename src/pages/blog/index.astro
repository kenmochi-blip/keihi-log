---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmtDate = (d: Date) =>
  d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });

const readingTime = (body: string | undefined) =>
  Math.max(1, Math.ceil((body?.length ?? 0) / 400));

// タグ一覧を集計
const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ブログ｜経費ログ</title>
  <meta name="description" content="経費精算・電子帳簿保存法・フリーランスの経費管理に関するお役立ち情報を発信しています。" />
  <link rel="canonical" href="https://keihi-log.com/blog" />
  <!-- OGP / Twitter Card -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="経費ログ" />
  <meta property="og:title" content="ブログ｜経費ログ" />
  <meta property="og:description" content="経費精算・電子帳簿保存法・フリーランスの経費管理に関するお役立ち情報を発信しています。" />
  <meta property="og:url" content="https://keihi-log.com/blog" />
  <meta property="og:image" content="https://keihi-log.com/icons/icon-512.png" />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="ブログ｜経費ログ" />
  <meta name="twitter:description" content="経費精算・電帳法・フリーランスの経費管理に関するお役立ち情報。" />
  <meta name="twitter:image" content="https://keihi-log.com/icons/icon-512.png" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <style>
    :root {
      --brand-h: 217; --brand-s: 97%; --brand-l: 52%;
      --brand: hsl(var(--brand-h), var(--brand-s), var(--brand-l));
      --bs-primary: var(--brand);
      --bs-primary-rgb: 13, 110, 253;
      --text: #212529;
      --muted: #6c757d;
      --border: #e9ecef;
      --bg: #f7f8fc;
    }
    body {
      font-family: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
    }

    /* ナビバー（LP統一） */
    .blog-nav {
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(10px);
      box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    }
    .blog-nav .brand { font-weight: 900; color: var(--brand); font-size: 1.35rem; text-decoration: none; display: inline-flex; align-items: center; }
    .blog-nav .logo-svg { width: 32px; height: 32px; margin-right: 6px; }
    .blog-nav .nav-link-sm { color: #495057; font-weight: 500; font-size: 0.88rem; text-decoration: none; }
    .blog-nav .nav-link-sm:hover { color: var(--brand); }

    /* ヒーロー（LPのブルー基調・紫は使わない） */
    .blog-hero {
      background: linear-gradient(135deg, var(--brand) 0%, hsl(var(--brand-h), var(--brand-s), 42%) 100%);
      color: #fff;
      padding: 4.5rem 1rem 4rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .blog-hero::after {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 80% -20%, rgba(255,255,255,0.18), transparent 55%);
      pointer-events: none;
    }
    .blog-hero .eyebrow {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      opacity: 0.85;
      margin-bottom: 0.9rem;
      position: relative;
    }
    .blog-hero h1 { font-size: 2.2rem; font-weight: 900; letter-spacing: 0.01em; margin-bottom: 0.8rem; position: relative; }
    .blog-hero p { opacity: 0.9; font-size: 0.92rem; margin: 0 auto; max-width: 560px; line-height: 1.8; position: relative; }
    @media (max-width: 575px) { .blog-hero h1 { font-size: 1.7rem; } }

    /* タグフィルター */
    .tag-filter-btn {
      background: #fff;
      border: 1.5px solid var(--border);
      border-radius: 20px;
      font-size: 0.78rem;
      font-weight: 500;
      padding: 0.3em 0.9em;
      cursor: pointer;
      transition: all 0.15s;
      color: var(--muted);
    }
    .tag-filter-btn:hover, .tag-filter-btn.active {
      background: var(--brand);
      border-color: var(--brand);
      color: #fff;
    }

    /* 記事カード */
    .post-card {
      background: #fff;
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      transition: transform 0.18s, box-shadow 0.18s;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      height: 100%;
    }
    .post-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(13,110,253,0.14);
    }
    .post-card-accent { height: 4px; background: linear-gradient(90deg, #29B6F6, #3F51B5); }
    .post-card-body { padding: 1.4rem 1.5rem; flex: 1; display: flex; flex-direction: column; }
    .post-tag { background: #eef4ff; color: var(--brand); font-size: 0.7rem; font-weight: 500; padding: 0.2em 0.65em; border-radius: 20px; }
    .post-title { font-size: 1rem; font-weight: 700; line-height: 1.5; margin: 0.5rem 0 0.6rem; color: var(--text); }
    .post-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.7; flex: 1; }
    .post-meta { font-size: 0.75rem; color: var(--muted); margin-top: 1rem; display: flex; gap: 0.75rem; }

    /* 空状態 */
    .empty-state { text-align: center; padding: 4rem 1rem; color: var(--muted); }

    /* フッター（LP統一・濃紺） */
    .blog-footer {
      background: linear-gradient(160deg, #0d2d5a 0%, #163866 100%);
      color: #adb5bd;
      border-top: 3px solid rgba(110, 168, 254, 0.5);
    }
    .blog-footer a { color: #adb5bd; text-decoration: none; transition: color 0.2s; }
    .blog-footer a:hover { color: #6ea8fe; }
  </style>
</head>
<body>

  <!-- ブランドロゴ定義 -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <symbol id="logo-keihilog" viewBox="0 0 100 100">
        <defs>
          <linearGradient id="logoGrad" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#29B6F6"/>
            <stop offset="100%" stop-color="#3F51B5"/>
          </linearGradient>
        </defs>
        <path d="M18,4 L74,4 Q80,4 80,10 L80,65 L72,73 L63,65 L55,73 L47,65 L38,73 L30,65 L22,73 L14,65 L14,10 Q14,4 18,4 Z" fill="url(#logoGrad)"/>
        <rect x="22" y="18" width="42" height="6" rx="3" fill="white"/>
        <rect x="22" y="30" width="37" height="6" rx="3" fill="white" opacity="0.9"/>
        <rect x="22" y="42" width="31" height="6" rx="3" fill="white" opacity="0.85"/>
        <circle cx="72" cy="76" r="22" fill="#388E3C"/>
        <polyline points="61,76 69,84 83,64" fill="none" stroke="white" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
      </symbol>
    </defs>
  </svg>

  <nav class="blog-nav py-2 px-3 px-md-4 d-flex align-items-center justify-content-between sticky-top">
    <a href="/" class="brand">
      <svg class="logo-svg"><use href="#logo-keihilog"/></svg>
      経費ログ
    </a>
    <div class="d-flex gap-3 align-items-center">
      <a href="/faq" class="nav-link-sm d-none d-sm-inline">FAQ</a>
      <a href="/guide" class="nav-link-sm d-none d-sm-inline">使い方</a>
      <a href="/" class="btn btn-primary btn-sm rounded-pill px-3" style="font-size:0.82rem;">無料で試す</a>
    </div>
  </nav>

  <!-- ヒーロー -->
  <div class="blog-hero">
    <span class="eyebrow">KEIHI-LOG BLOG</span>
    <h1>経費まわりの「困った」を解決する</h1>
    <p>経費精算・電子帳簿保存法・フリーランスの経費管理について、<br class="d-none d-md-inline">実務で役立つ情報をやさしく解説します。</p>
  </div>

  <main class="container py-5" style="max-width:920px;">

    <!-- タグフィルター -->
    {allTags.length > 0 && (
      <div class="d-flex flex-wrap gap-2 mb-4" id="tagFilters">
        <button class="tag-filter-btn active" data-tag="">すべて</button>
        {allTags.map(tag => (
          <button class="tag-filter-btn" data-tag={tag}>#{tag}</button>
        ))}
      </div>
    )}

    <!-- 記事一覧 -->
    {posts.length === 0 ? (
      <div class="empty-state">
        <i class="bi bi-journal-text" style="font-size:3rem;opacity:0.3;"></i>
        <p class="mt-3">記事はまだありません。</p>
      </div>
    ) : (
      <div class="row g-4" id="postGrid">
        {posts.map(post => (
          <div class="col-12 col-md-6" data-tags={post.data.tags.join(',')}>
            <a href={`/blog/${post.id}/`} class="post-card">
              <div class="post-card-accent"></div>
              <div class="post-card-body">
                <div class="d-flex flex-wrap gap-1">
                  {post.data.tags.map(tag => (
                    <span class="post-tag">#{tag}</span>
                  ))}
                </div>
                <div class="post-title">{post.data.title}</div>
                <p class="post-desc">{post.data.description}</p>
                <div class="post-meta">
                  <span><i class="bi bi-calendar3 me-1"></i>
                    <time datetime={post.data.pubDate.toISOString()}>
                      {fmtDate(post.data.pubDate)}
                    </time>
                  </span>
                  <span><i class="bi bi-clock me-1"></i>約{readingTime(post.body)}分</span>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    )}
  </main>

  <footer class="blog-footer py-4">
    <div class="container text-center" style="font-size:0.8rem;">
      <div class="d-flex justify-content-center flex-wrap gap-3 mb-2">
        <a href="/privacy">プライバシーポリシー</a>
        <a href="/terms">利用規約</a>
        <a href="/faq">よくある質問</a>
        <a href="/">アプリトップ</a>
      </div>
      <div style="opacity:0.7;">© 2025 合同会社Smart&amp;Smooth</div>
    </div>
  </footer>

  <script>
    // タグフィルター
    const filterBtns = document.querySelectorAll('.tag-filter-btn');
    const cards = document.querySelectorAll('#postGrid [data-tags]');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const tag = (btn as HTMLButtonElement).dataset.tag ?? '';
        cards.forEach(card => {
          const el = card as HTMLElement;
          const tags = el.dataset.tags ?? '';
          el.style.display = (!tag || tags.split(',').includes(tag)) ? '' : 'none';
        });
      });
    });
  </script>

</body>
</html>
