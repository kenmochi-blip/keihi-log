{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/success", "destination": "/success.html" },
    { "source": "/licenses", "destination": "/licenses.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/((?!js/|css/|api/|app\\.html|privacy\\.html|privacy|success\\.html|success|licenses\\.html|licenses|faq\\.html|faq|demo\\.html|demo/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
